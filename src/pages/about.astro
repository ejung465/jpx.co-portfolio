---
import Base from "@/layouts/Base.astro";
import DraftNote from "@/components/DraftNote.astro";
---

<Base
  title="About — Ethan Jung"
  description="Full-stack developer building websites and web applications for small businesses and nonprofits."
>
  <div class="max-w-[640px] mx-auto px-8 pt-16 pb-24">
    <span class="eyebrow mb-4">About</span>
    <h1 class="text-[36px] md:text-[46px] mt-4 mb-6">Hi, I'm Ethan.</h1>

    <DraftNote label="Needs your voice">
      This page is the second-biggest lever on the whole site after the case studies — it's where a real photo and
      a few true sentences do more than any amount of design polish. Tell me: your background (self-taught? CS
      degree? how'd you get into full-stack dev), what got you into building for nonprofits and small businesses
      specifically, your town/service area, and anything outside of code worth mentioning. I'll write this in your
      voice, not a generic "passionate developer" bio.
    </DraftNote>

    <div class="prose-case mt-8">
      <p>
        I build full-stack web applications — not just marketing sites, but the registration flows, admin
        dashboards, and unglamorous infrastructure that make a small organization's day-to-day actually work.
      </p>
      <p>
        I work directly with the people I build for. No account managers, no outsourced backend — just one person
        who writes the code, reviews it, and answers the phone after launch.
      </p>
    </div>

    <div class="mt-16 flex items-center gap-5">
      <a href="/contact" class="btn-neu inline-block">Book a 20-min call</a>
      <a class="link-ghost" href="/#work">See the work <span class="arr">→</span></a>
    </div>
  </div>
</Base>
