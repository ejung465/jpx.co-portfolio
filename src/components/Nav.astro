---
const links = [
  { href: "/#work", label: "Work" },
  { href: "/#approach", label: "Approach" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<nav class="site-nav glass mx-4 sm:mx-auto">
  <a href="/" class="flex items-center gap-2.5 font-semibold tracking-tight text-[15px]">
    <span class="nav-mark">EJ</span>
    Ethan Jung
  </a>

  <div class="hidden md:flex gap-7 text-[14.5px]" style="color: var(--ink-soft);">
    {links.map((link) => (
      <a href={link.href} class="hover:text-[var(--ink)] transition-colors">{link.label}</a>
    ))}
  </div>

  <div class="flex items-center gap-2">
    <a href="/contact" class="text-[14px] font-medium text-white rounded-[11px] px-[18px] py-[10px]"
      style="background: var(--ink); box-shadow: 0 4px 14px rgba(22,26,29,.22);">
      Book a call
    </a>
    <button
      id="nav-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      class="md:hidden grid place-items-center w-9 h-9 rounded-[10px]"
      style="border: 1px solid var(--glass-line);"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 4h14M1 8h14M1 12h14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
</nav>

<div id="nav-mobile" class="glass md:hidden mx-4 mt-2 rounded-[16px] p-2 hidden">
  {links.map((link) => (
    <a href={link.href} class="block px-4 py-3 text-[15px] rounded-[10px]" style="color: var(--ink);">
      {link.label}
    </a>
  ))}
</div>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-mobile");
  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });
</script>
