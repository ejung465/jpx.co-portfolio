---
interface Props {
  label?: string;
}
const { label = "Draft" } = Astro.props;
---

<div
  class="rounded-[14px] px-5 py-4 my-6 text-[14px]"
  style="border: 1px dashed var(--glass-line); background: var(--surface); color: var(--ink-soft);"
>
  <span class="tag tag-warm mr-2">{label}</span>
  <slot />
</div>
